{
  "name": "pds-commerce-suite",
  "version": "4.5.0",
  "description": "Paramount E-mart — Advanced e-commerce suite with MongoDB, authentication, and real payments",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "NODE_ENV=development nodemon server.js",
    "production": "NODE_ENV=production node server.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:reload": "pm2 reload paramount-store",
    "pm2:stop": "pm2 stop paramount-store",
    "pm2:logs": "pm2 logs paramount-store",
    "test": "jest --detectOpenHandles --forceExit",
    "lint": "eslint .",
    "setup:db": "node scripts/setup-db.js"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "ecommerce",
    "nigeria",
    "paystack",
    "flutterwave",
    "paypal",
    "store",
    "mongodb",
    "authentication"
  ],
  "author": "Paramount Digital Services",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "axios": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.35.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "express-validator": "^7.0.0",
    "helmet": "^7.0.0",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.1",
    "sharp": "^0.32.0",
    "stripe": "^11.15.0"
  },
  "devDependencies": {
    "eslint": "^8.40.0",
    "jest": "^29.5.0",
    "nodemon": "^2.0.20",
    "supertest": "^6.3.3"
  }
}
